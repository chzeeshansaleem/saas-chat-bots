NODE_ENV=development

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=multi_chatbot
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=12345

# Optional. If omitted, backend builds this from POSTGRES_* variables.
DATABASE_URL=postgresql://postgres:12345@127.0.0.1:5432/multi_chatbot?schema=public

REDIS_HOST=redis
REDIS_PORT=6379

JWT_ACCESS_SECRET=replace-me-access-secret
JWT_REFRESH_SECRET=replace-me-refresh-secret
JWT_ACCESS_TTL=60m
JWT_REFRESH_TTL=30d

OPENAI_API_KEY=sk-replace-me
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

BACKEND_PORT=4000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
