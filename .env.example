NODE_ENV=development

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=multi_chatbot
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=12345

# Optional. If omitted, backend builds this from POSTGRES_* variables.
DATABASE_URL=postgresql://postgres:12345@127.0.0.1:5432/multi_chatbot?schema=public

REDIS_HOST=redis
REDIS_PORT=6379

JWT_ACCESS_SECRET=replace-me-access-secret
JWT_REFRESH_SECRET=replace-me-refresh-secret
JWT_ACCESS_TTL=60m
JWT_REFRESH_TTL=30d

OPENAI_API_KEY=sk-replace-me
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

BACKEND_PORT=4000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# Phase 3 integrations and action agents
BACKEND_PUBLIC_URL=http://localhost:4000
ENCRYPTION_KEY=replace-with-32-plus-character-secret
WEBHOOK_SECRET=replace-with-webhook-secret
ACTION_QUEUE_CONCURRENCY=3
SYNC_QUEUE_CONCURRENCY=2
WIDGET_CDN_URL=http://localhost:5173/widget.js
WIDGET_ALLOWED_DEV_ORIGINS=http://localhost:3000,http://localhost:5173
CUSTOM_API_ALLOW_PRIVATE_URLS=false

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
