generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum Role {
  ADMIN
  MEMBER
}

enum KnowledgeSourceType {
  WEBSITE
  PDF
  DOCX
  TXT
}

enum KnowledgeSourceStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum CrawlJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum ChatSessionStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum ChatTitleJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum IntegrationAuthType {
  OAUTH2
  API_KEY
  BEARER_TOKEN
  BASIC
  NONE
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  EXPIRED
}

enum ToolActionType {
  READ
  WRITE
  DELETE
}

enum ActionRequestStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  EXECUTING
  SUCCESS
  FAILED
  CANCELLED
}

enum ActionLogStatus {
  SUCCESS
  FAILED
  CANCELLED
}

enum HttpMethod {
  GET
  POST
  PATCH
  PUT
  DELETE
}

enum BotStatus {
  ACTIVE
  DISABLED
}

enum WidgetPosition {
  BOTTOM_RIGHT
  BOTTOM_LEFT
}

enum WidgetSessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum ToolExecutionStatus {
  PENDING_CONFIRMATION
  EXECUTING
  SUCCESS
  FAILED
  CANCELLED
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  name         String?
  passwordHash String       @map("password_hash")
  refreshHash  String?      @map("refresh_hash")
  memberships  Membership[]
  connectedIntegrations TenantIntegration[]
  actionRequests ActionRequest[]
  actionLogs     ActionLog[]
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@map("users")
}

model Tenant {
  id               String            @id @default(uuid())
  name             String
  slug             String            @unique
  memberships      Membership[]
  knowledgeSources KnowledgeSource[]
  documents        Document[]
  documentChunks   DocumentChunk[]
  chatSessions     ChatSession[]
  chatTitleJobs     ChatTitleJob[]
  crawlJobs        CrawlJob[]
  tenantIntegrations TenantIntegration[]
  actionRequests   ActionRequest[]
  actionLogs       ActionLog[]
  webhookEndpoints WebhookEndpoint[]
  webhookEvents    WebhookEvent[]
  externalResourceCaches ExternalResourceCache[]
  customApiConnectors CustomApiConnector[]
  bots             Bot[]
  widgetUsers      WidgetUser[]
  widgetSessions   WidgetSession[]
  apiConnectors    ApiConnector[]
  authConfigs      AuthConfig[]
  oauthConnections OAuthConnection[]
  apiCredentials   ApiCredential[]
  toolExecutions   ToolExecution[]
  actionConfirmations ActionConfirmation[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@map("tenants")
}

model Membership {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tenantId  String   @map("tenant_id")
  role      Role     @default(MEMBER)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@map("memberships")
}

model KnowledgeSource {
  id          String                @id @default(uuid())
  tenantId    String                @map("tenant_id")
  type        KnowledgeSourceType
  status      KnowledgeSourceStatus @default(PENDING)
  name        String
  url         String?
  filePath    String?               @map("file_path")
  metadata    Json                  @default("{}")
  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents   Document[]
  crawlJobs   CrawlJob[]
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  @@index([tenantId, type])
  @@map("knowledge_sources")
}

model Document {
  id                String          @id @default(uuid())
  tenantId          String          @map("tenant_id")
  knowledgeSourceId String          @map("knowledge_source_id")
  title             String
  uri               String
  contentHash       String          @map("content_hash")
  rawText           String          @map("raw_text")
  metadata          Json            @default("{}")
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  knowledgeSource   KnowledgeSource @relation(fields: [knowledgeSourceId], references: [id], onDelete: Cascade)
  chunks            DocumentChunk[]
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@unique([tenantId, contentHash])
  @@index([tenantId, knowledgeSourceId])
  @@map("documents")
}

model DocumentChunk {
  id         String     @id @default(uuid())
  tenantId   String     @map("tenant_id")
  documentId String     @map("document_id")
  ordinal    Int
  content    String
  tokenCount Int        @map("token_count")
  metadata   Json       @default("{}")
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document   Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embedding  Embedding?
  createdAt  DateTime   @default(now()) @map("created_at")

  @@unique([documentId, ordinal])
  @@index([tenantId, documentId])
  @@map("document_chunks")
}

model Embedding {
  id        String                  @id @default(uuid())
  chunkId   String                  @unique @map("chunk_id")
  tenantId  String                  @map("tenant_id")
  model     String
  vector    Unsupported("vector(1536)")
  chunk     DocumentChunk           @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  createdAt DateTime                @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("embeddings")
}

model ChatSession {
  id                  String            @id @default(uuid())
  tenantId            String            @map("tenant_id")
  userId              String            @map("user_id")
  botId               String?           @map("bot_id")
  widgetSessionId     String?           @map("widget_session_id")
  title               String            @default("New Chat")
  titleManuallyEdited Boolean           @default(false) @map("title_manually_edited")
  status              ChatSessionStatus @default(ACTIVE)
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bot                 Bot?              @relation(fields: [botId], references: [id], onDelete: SetNull)
  widgetSession       WidgetSession?    @relation(fields: [widgetSessionId], references: [id], onDelete: SetNull)
  messages            ChatMessage[]
  titleJobs           ChatTitleJob[]
  toolExecutions      ToolExecution[]
  actionConfirmations ActionConfirmation[]
  actionLogs          ActionLog[]
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  lastMessageAt       DateTime?         @map("last_message_at")

  @@index([tenantId, userId, status])
  @@index([tenantId, botId, status])
  @@index([widgetSessionId])
  @@index([tenantId, updatedAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id            String          @id @default(uuid())
  tenantId      String          @map("tenant_id")
  chatSessionId String          @map("session_id")
  userId        String?         @map("user_id")
  role          ChatMessageRole
  content       String
  metadata      Json            @default("{}")
  sources       Json            @default("[]")
  tokenUsage    Json            @default("{}") @map("token_usage")
  tokenCount    Int?            @map("token_count")
  session       ChatSession     @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now()) @map("created_at")

  @@index([tenantId, chatSessionId, createdAt])
  @@index([tenantId, userId, createdAt])
  @@map("chat_messages")
}

model ChatTitleJob {
  id            String             @id @default(uuid())
  tenantId      String             @map("tenant_id")
  chatSessionId String             @map("chat_session_id")
  status        ChatTitleJobStatus @default(PENDING)
  generatedTitle String?           @map("generated_title")
  errorMessage  String?            @map("error_message")
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session       ChatSession        @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now()) @map("created_at")
  completedAt   DateTime?          @map("completed_at")

  @@index([tenantId, chatSessionId, status])
  @@map("chat_title_jobs")
}

model IntegrationProvider {
  id        String              @id @default(uuid())
  name      String
  key       String              @unique
  authType  IntegrationAuthType @map("auth_type")
  oauthConfig Json              @default("{}") @map("oauth_config")
  scopes    String[]            @default([])
  integrations TenantIntegration[]
  tools     ToolDefinition[]
  webhookEndpoints WebhookEndpoint[]
  webhookEvents WebhookEvent[]
  externalResourceCaches ExternalResourceCache[]
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  @@map("integration_providers")
}

model TenantIntegration {
  id                    String            @id @default(uuid())
  tenantId              String            @map("tenant_id")
  providerId            String            @map("provider_id")
  connectedByUserId     String            @map("connected_by_user_id")
  status                IntegrationStatus @default(CONNECTED)
  accessTokenEncrypted  String?           @map("access_token_encrypted")
  refreshTokenEncrypted String?           @map("refresh_token_encrypted")
  expiresAt             DateTime?         @map("expires_at")
  scopes                String[]          @default([])
  metadata              Json              @default("{}")
  tenant                Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider              IntegrationProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  connectedBy           User              @relation(fields: [connectedByUserId], references: [id], onDelete: Cascade)
  actionLogs            ActionLog[]
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  @@unique([tenantId, providerId])
  @@index([tenantId, status])
  @@map("tenant_integrations")
}

model ToolDefinition {
  id                    String         @id @default(uuid())
  providerId            String         @map("provider_id")
  name                  String
  key                   String         @unique
  description           String
  actionType            ToolActionType @map("action_type")
  inputSchema           Json           @default("{}") @map("input_schema")
  requiredScopes        String[]       @default([]) @map("required_scopes")
  confirmationRequired  Boolean        @default(false) @map("confirmation_required")
  enabled               Boolean        @default(true)
  provider              IntegrationProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  actionRequests        ActionRequest[]
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  @@index([providerId, enabled])
  @@map("tool_definitions")
}

model ActionRequest {
  id                    String              @id @default(uuid())
  tenantId              String              @map("tenant_id")
  userId                String              @map("user_id")
  toolId                String              @map("tool_id")
  status                ActionRequestStatus @default(PENDING_CONFIRMATION)
  inputPayload          Json                @default("{}") @map("input_payload")
  outputPayload         Json                @default("{}") @map("output_payload")
  errorMessage          String?             @map("error_message")
  requiresConfirmation  Boolean             @default(true) @map("requires_confirmation")
  confirmedAt           DateTime?           @map("confirmed_at")
  executedAt            DateTime?           @map("executed_at")
  tenant                Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool                  ToolDefinition      @relation(fields: [toolId], references: [id], onDelete: Cascade)
  createdAt             DateTime            @default(now()) @map("created_at")

  @@index([tenantId, userId, status])
  @@map("action_requests")
}

model ActionLog {
  id            String          @id @default(uuid())
  tenantId      String          @map("tenant_id")
  userId        String?         @map("user_id")
  botId         String?         @map("bot_id")
  chatSessionId String?         @map("chat_session_id")
  integrationId String?         @map("integration_id")
  toolName      String          @map("tool_name")
  actionType    ToolActionType  @map("action_type")
  inputPayload  Json            @default("{}") @map("input_payload")
  outputPayload Json            @default("{}") @map("output_payload")
  status        ActionLogStatus
  errorMessage  String?         @map("error_message")
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  bot           Bot?            @relation(fields: [botId], references: [id], onDelete: SetNull)
  chatSession   ChatSession?    @relation(fields: [chatSessionId], references: [id], onDelete: SetNull)
  integration   TenantIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  confirmedAt   DateTime?       @map("confirmed_at")
  executedAt    DateTime?       @map("executed_at")
  createdAt     DateTime        @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([tenantId, botId, createdAt])
  @@index([tenantId, chatSessionId])
  @@index([tenantId, toolName])
  @@map("action_logs")
}

model Bot {
  id                       String         @id @default(uuid())
  tenantId                 String         @map("tenant_id")
  name                     String
  avatarUrl                String?        @map("avatar_url")
  welcomeMessage           String         @default("Hi, how can I help?") @map("welcome_message")
  placeholder              String         @default("Ask me anything...") @map("placeholder")
  themeColor               String         @default("#2563eb") @map("theme_color")
  position                 WidgetPosition @default(BOTTOM_RIGHT)
  zIndex                   Int            @default(2147483000) @map("z_index")
  status                   BotStatus      @default(ACTIVE)
  suggestedQuestions       String[]       @default([]) @map("suggested_questions")
  allowAnonymous           Boolean        @default(true) @map("allow_anonymous")
  requireSignedIdentity    Boolean        @default(false) @map("require_signed_identity")
  identitySecretEncrypted  String?        @map("identity_secret_encrypted")
  tenant                   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  domains                  BotDomain[]
  widgetSessions           WidgetSession[]
  chatSessions             ChatSession[]
  actionLogs               ActionLog[]
  toolExecutions           ToolExecution[]
  actionConfirmations      ActionConfirmation[]
  createdAt                DateTime       @default(now()) @map("created_at")
  updatedAt                DateTime       @updatedAt @map("updated_at")

  @@index([tenantId, status])
  @@map("bots")
}

model BotDomain {
  id        String   @id @default(uuid())
  botId     String   @map("bot_id")
  domain    String
  enabled   Boolean  @default(true)
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([botId, domain])
  @@index([domain, enabled])
  @@map("bot_domains")
}

model WidgetUser {
  id             String          @id @default(uuid())
  tenantId       String          @map("tenant_id")
  externalUserId String?         @map("external_user_id")
  email          String?
  name           String?
  authMode       String          @default("anonymous") @map("auth_mode")
  metadata       Json            @default("{}")
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions       WidgetSession[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([tenantId, externalUserId])
  @@index([tenantId, email])
  @@map("widget_users")
}

model WidgetSession {
  id               String              @id @default(uuid())
  tenantId         String              @map("tenant_id")
  botId            String              @map("bot_id")
  widgetUserId     String              @map("widget_user_id")
  sessionTokenHash String              @unique @map("session_token_hash")
  origin           String?
  status           WidgetSessionStatus @default(ACTIVE)
  lastSeenAt       DateTime            @default(now()) @map("last_seen_at")
  expiresAt        DateTime?           @map("expires_at")
  metadata         Json                @default("{}")
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bot              Bot                 @relation(fields: [botId], references: [id], onDelete: Cascade)
  widgetUser       WidgetUser          @relation(fields: [widgetUserId], references: [id], onDelete: Cascade)
  chatSessions     ChatSession[]
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  @@index([tenantId, botId, status])
  @@index([widgetUserId, status])
  @@map("widget_sessions")
}

model ApiConnector {
  id                  String              @id @default(uuid())
  tenantId            String              @map("tenant_id")
  name                String
  baseUrl             String              @map("base_url")
  authType            IntegrationAuthType @map("auth_type")
  authConfigEncrypted String?             @map("auth_config_encrypted")
  headersEncrypted    String?             @map("headers_encrypted")
  enabled             Boolean             @default(true)
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endpoints           ApiEndpoint[]
  authConfigs         AuthConfig[]
  oauthConnections    OAuthConnection[]
  apiCredentials      ApiCredential[]
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@index([tenantId, enabled])
  @@map("api_connectors")
}

model ApiEndpoint {
  id                   String             @id @default(uuid())
  connectorId          String             @map("connector_id")
  name                 String
  toolKey              String             @map("tool_key")
  method               HttpMethod
  path                 String
  description          String
  inputSchema          Json               @default("{}") @map("input_schema")
  requestMapping       Json               @default("{}") @map("request_mapping")
  responseMapping      Json               @default("{}") @map("response_mapping")
  confirmationRequired Boolean            @default(false) @map("confirmation_required")
  allowedRoles         String[]           @default(["admin", "member"]) @map("allowed_roles")
  enabled              Boolean            @default(true)
  connector            ApiConnector       @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  toolExecutions       ToolExecution[]
  actionConfirmations  ActionConfirmation[]
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@unique([connectorId, toolKey])
  @@index([toolKey, enabled])
  @@index([connectorId, enabled])
  @@map("api_endpoints")
}

model ToolExecution {
  id            String              @id @default(uuid())
  tenantId      String              @map("tenant_id")
  botId         String?             @map("bot_id")
  widgetUserId  String?             @map("widget_user_id")
  chatSessionId String?             @map("chat_session_id")
  endpointId    String              @map("endpoint_id")
  toolKey       String              @map("tool_key")
  status        ToolExecutionStatus @default(EXECUTING)
  inputPayload  Json                @default("{}") @map("input_payload")
  outputPayload Json                @default("{}") @map("output_payload")
  errorMessage  String?             @map("error_message")
  confirmedAt   DateTime?           @map("confirmed_at")
  executedAt    DateTime?           @map("executed_at")
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bot           Bot?                @relation(fields: [botId], references: [id], onDelete: SetNull)
  chatSession   ChatSession?        @relation(fields: [chatSessionId], references: [id], onDelete: SetNull)
  endpoint      ApiEndpoint         @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([tenantId, toolKey, status])
  @@index([chatSessionId, createdAt])
  @@map("tool_executions")
}

model ActionConfirmation {
  id            String              @id @default(uuid())
  tenantId      String              @map("tenant_id")
  botId         String?             @map("bot_id")
  widgetUserId  String?             @map("widget_user_id")
  chatSessionId String?             @map("chat_session_id")
  endpointId    String              @map("endpoint_id")
  status        ToolExecutionStatus @default(PENDING_CONFIRMATION)
  preview       Json                @default("{}")
  inputPayload  Json                @default("{}") @map("input_payload")
  confirmedAt   DateTime?           @map("confirmed_at")
  expiresAt     DateTime?           @map("expires_at")
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bot           Bot?                @relation(fields: [botId], references: [id], onDelete: SetNull)
  chatSession   ChatSession?        @relation(fields: [chatSessionId], references: [id], onDelete: SetNull)
  endpoint      ApiEndpoint         @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([tenantId, status])
  @@index([chatSessionId, status])
  @@map("action_confirmations")
}

model AuthConfig {
  id                  String              @id @default(uuid())
  tenantId            String              @map("tenant_id")
  connectorId         String?             @map("connector_id")
  name                String
  authType            IntegrationAuthType @map("auth_type")
  configEncrypted     String?             @map("config_encrypted")
  enabled             Boolean             @default(true)
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connector           ApiConnector?       @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@index([tenantId, enabled])
  @@map("auth_configs")
}

model OAuthConnection {
  id                    String            @id @default(uuid())
  tenantId              String            @map("tenant_id")
  connectorId           String?           @map("connector_id")
  externalUserId        String?           @map("external_user_id")
  accessTokenEncrypted  String?           @map("access_token_encrypted")
  refreshTokenEncrypted String?           @map("refresh_token_encrypted")
  scopes                String[]          @default([])
  expiresAt             DateTime?         @map("expires_at")
  metadata              Json              @default("{}")
  tenant                Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connector             ApiConnector?     @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  @@index([tenantId, connectorId])
  @@map("oauth_connections")
}

model ApiCredential {
  id                  String        @id @default(uuid())
  tenantId            String        @map("tenant_id")
  connectorId         String?       @map("connector_id")
  name                String
  secretEncrypted     String        @map("secret_encrypted")
  metadata            Json          @default("{}")
  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connector           ApiConnector? @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  @@index([tenantId, connectorId])
  @@map("api_credentials")
}

model WebhookEndpoint {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  providerId String    @map("provider_id")
  secret     String
  url        String
  enabled    Boolean   @default(true)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider   IntegrationProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, providerId])
  @@map("webhook_endpoints")
}

model WebhookEvent {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  providerId  String    @map("provider_id")
  eventType   String    @map("event_type")
  payload     Json      @default("{}")
  processed   Boolean   @default(false)
  processedAt DateTime? @map("processed_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider    IntegrationProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tenantId, providerId, processed])
  @@map("webhook_events")
}

model ExternalResourceCache {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  providerId   String   @map("provider_id")
  resourceType String   @map("resource_type")
  externalId   String   @map("external_id")
  data         Json     @default("{}")
  syncedAt     DateTime @default(now()) @map("synced_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider     IntegrationProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, providerId, resourceType, externalId])
  @@index([tenantId, resourceType])
  @@map("external_resource_cache")
}

model CustomApiConnector {
  id                  String              @id @default(uuid())
  tenantId            String              @map("tenant_id")
  name                String
  baseUrl             String              @map("base_url")
  authType            IntegrationAuthType @map("auth_type")
  authConfigEncrypted String?             @map("auth_config_encrypted")
  headersEncrypted    String?             @map("headers_encrypted")
  enabled             Boolean             @default(true)
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endpoints           CustomApiEndpoint[]
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@index([tenantId, enabled])
  @@map("custom_api_connectors")
}

model CustomApiEndpoint {
  id                   String             @id @default(uuid())
  connectorId          String             @map("connector_id")
  name                 String
  method               HttpMethod
  path                 String
  description          String
  inputSchema          Json               @default("{}") @map("input_schema")
  responseMapping      Json               @default("{}") @map("response_mapping")
  confirmationRequired Boolean            @default(false) @map("confirmation_required")
  allowedRoles         String[]           @default(["ADMIN"]) @map("allowed_roles")
  enabled              Boolean            @default(true)
  connector            CustomApiConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@index([connectorId, enabled])
  @@map("custom_api_endpoints")
}

model CrawlJob {
  id                String          @id @default(uuid())
  tenantId          String          @map("tenant_id")
  knowledgeSourceId String          @map("knowledge_source_id")
  rootUrl           String          @map("root_url")
  status            CrawlJobStatus  @default(QUEUED)
  depth             Int             @default(2)
  pageLimit         Int             @default(50) @map("page_limit")
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  knowledgeSource   KnowledgeSource @relation(fields: [knowledgeSourceId], references: [id], onDelete: Cascade)
  logs              CrawlLog[]
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@index([tenantId, status])
  @@map("crawl_jobs")
}

model CrawlLog {
  id         String   @id @default(uuid())
  crawlJobId String   @map("crawl_job_id")
  url        String
  statusCode Int?     @map("status_code")
  message    String?
  crawledAt  DateTime @default(now()) @map("crawled_at")
  crawlJob   CrawlJob @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)

  @@index([crawlJobId])
  @@map("crawl_logs")
}
